# =====================================================================
# Afya Sahihi - .gitignore
# =====================================================================

# Environment files - the committed ones are *.env templates, real
# values live in Sealed Secrets or systemd credentials
.env
.env.local
.env.*.local
!env/.env.root
!env/*.env

# Secrets - the baseline is committed, actual secrets never are
*.pem
*.key
*.crt
!deploy/**/ca.crt.example
*.jks
*.p12
secrets/
credentials/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.pyright/

# uv
.venv/
venv/
ENV/
env.bak/
venv.bak/
uv.lock.bak

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn-integrity
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.turbo/

# Frontend build output
*.tsbuildinfo

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# Docker
.docker/

# k3s / kubeconfig (never commit live kubeconfigs)
kubeconfig
kubeconfig.yaml
*.kubeconfig

# HF cache
.huggingface/
hf-cache/

# Model weights (large, pulled via pipeline)
*.safetensors
*.bin
*.gguf
*.pt
*.pth
!samples/**/*.safetensors  # test fixtures may commit small models

# Data (never commit real clinical data)
data/
datasets/
!eval/datasets/
eval/datasets/*.jsonl.local
*.parquet
*.arrow

# Logs
logs/
*.log
journald-*
!docs/**/*.log.example

# Temp
tmp/
temp/
*.tmp
*.bak
.cache/

# OS
Thumbs.db
desktop.ini

# Helm / kustomize build output
charts/
*.tgz
kustomize-build/

# Terraform (if we add any)
.terraform/
*.tfstate
*.tfstate.*
.terraformrc
terraform.rc

# Secrets baseline (checked in, but only the digest)
!.secrets.baseline

# Local dev overrides
docker-compose.override.yaml
docker-compose.override.yml

# Inspect AI logs (can be large)
eval/logs/
eval/outputs/

# Generated API specs
openapi.json
openapi.yaml

# Pre-commit
.pre-commit-cache/

# Issue grinder prompt (internal tooling, not committed)
scripts/issue_grinder_prompt.sh

# Claude Code session state (per-user, never committed)
.claude/

# Local automation scripts (keep hook scripts tracked, ignore everything else)
scripts/*.sh
!scripts/hooks/*.sh
!scripts/bootstrap_issues.sh
!scripts/dev_install.sh
