## =====================================================================
## Afya Sahihi - Conformal Prediction Service
## =====================================================================
## Constructs prediction sets, tracks coverage, alerts on drift.
## =====================================================================

SERVICE_NAME=afya-sahihi-conformal
SERVICE_PORT=8082
SERVICE_WORKERS=2
SERVICE_LOG_LEVEL=info

## ---- Method -----------------------------------------------------------
CP_METHOD=weighted_split                 # weighted_split | adaptive | mondrian | split
CP_TARGET_COVERAGE=0.90
CP_ALPHA=0.10

## ---- Nonconformity score -----------------------------------------------
## Implemented variants:
##   nll                       - Negative log-likelihood of generated sequence
##   retrieval_weighted        - NLL / f(top-1 retrieval similarity)
##   topic_coherence_adjusted  - Incorporates pre-filter confidence
##   ensemble_disagreement     - Via sampled generations
##   clinical_harm_weighted    - Errors weighted by clinical harm taxonomy
NONCONFORMITY_SCORE=clinical_harm_weighted

## ---- Stratification ---------------------------------------------------
## Comma-separated dimensions along which quantiles are computed
## separately for conditional coverage.
CP_STRATA=domain,language,facility_level,query_complexity

## ---- Calibration set --------------------------------------------------
CALIBRATION_SET_MIN_SIZE_PER_STRATUM=100
CALIBRATION_SET_MAX_SIZE=10000
CALIBRATION_REFRESH_ON_STARTUP=true

## ---- Quantile caching -------------------------------------------------
QUANTILE_CACHE_BACKEND=redis
QUANTILE_CACHE_TTL_SECONDS=3600
QUANTILE_REFRESH_CRON="0 2 * * *"        # nightly at 02:00

## ---- Coverage monitoring ----------------------------------------------
COVERAGE_ROLLING_WINDOW_HOURS=24
COVERAGE_ALERT_THRESHOLD_DEVIATION=0.05  # alert if empirical deviates > 5pp from target
COVERAGE_ALERT_MIN_SAMPLES=200

## ---- Drift detection --------------------------------------------------
DRIFT_DETECTOR_ENABLED=true
DRIFT_DETECTOR_METHOD=mmd                # mmd | ks | classifier_based
DRIFT_DETECTOR_WINDOW_SIZE=500
DRIFT_DETECTOR_THRESHOLD=0.01

## ---- Clinical harm taxonomy -------------------------------------------
HARM_TAXONOMY_PATH=/etc/afya-sahihi/conformal/harm_taxonomy.yaml
HARM_WEIGHT_CATASTROPHIC=10.0            # wrong dose, wrong drug
HARM_WEIGHT_MAJOR=3.0                    # missed contraindication
HARM_WEIGHT_MODERATE=1.0                 # incomplete advice
HARM_WEIGHT_MINOR=0.3                    # phrasing, style
