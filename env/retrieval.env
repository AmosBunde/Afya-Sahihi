## =====================================================================
## Afya Sahihi - Retrieval Service
## =====================================================================
## Hybrid dense (pgvector) + sparse (pg_search Tantivy) + reranking.
## =====================================================================

SERVICE_NAME=afya-sahihi-retrieval
SERVICE_PORT=8081
SERVICE_WORKERS=4
SERVICE_LOG_LEVEL=info
SERVICE_LOG_FORMAT=json

## ---- Hybrid retrieval --------------------------------------------------
RETRIEVAL_DENSE_ENABLED=true
RETRIEVAL_SPARSE_ENABLED=true
RETRIEVAL_RERANK_ENABLED=true

## ---- Dense (pgvector) --------------------------------------------------
DENSE_SIMILARITY_METRIC=cosine
DENSE_EF_SEARCH=40                       # runtime HNSW parameter
DENSE_TOP_K_CANDIDATES=30                # pre-RRF

## ---- Sparse (pg_search / Tantivy) --------------------------------------
SPARSE_ANALYZER=english                  # english | default | raw
SPARSE_BM25_K1=1.2
SPARSE_BM25_B=0.75
SPARSE_TOP_K_CANDIDATES=30

## ---- Fusion (Reciprocal Rank Fusion) -----------------------------------
RRF_K_CONSTANT=60
FUSION_DENSE_WEIGHT=0.6
FUSION_SPARSE_WEIGHT=0.4

## ---- Cross-encoder reranker --------------------------------------------
RERANKER_MODEL_PATH=/srv/afya-sahihi/models/bge-reranker-v2-m3
RERANKER_DEVICE=cpu                      # small model, CPU inference is fine
RERANKER_BATCH_SIZE=16
RERANKER_MAX_LENGTH=512

## ---- Query embedder -----------------------------------------------------
QUERY_EMBEDDER_MODEL_PATH=/srv/afya-sahihi/models/bge-m3
QUERY_EMBEDDER_DEVICE=cpu
QUERY_EMBEDDER_BATCH_SIZE=8
QUERY_EMBEDDER_MATRYOSHKA_DIM=1024

## ---- Structural metadata filtering -------------------------------------
STRUCTURAL_FILTERS_ENABLED=true
STRUCTURAL_STRICT_MODE=false             # true = filters are hard constraints
STRUCTURAL_BOOST_CONTRAINDICATIONS=1.5
STRUCTURAL_BOOST_PEDIATRIC_ON_PEDIATRIC_QUERY=2.0

## ---- Caching ----------------------------------------------------------
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_SECONDS=900              # 15 minutes
QUERY_CACHE_MAX_KEYS=10000
