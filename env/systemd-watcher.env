## =====================================================================
## Afya Sahihi - systemd GitOps Watcher
## =====================================================================
## Runs on afya-sahihi-deploy-01. Polls the deployment manifests repo,
## runs kubectl apply on diff. Also manages the vLLM systemd units
## on afya-sahihi-gpu-01 via SSH-triggered re-pull.
## =====================================================================

SERVICE_NAME=afya-sahihi-watcher
SERVICE_LOG_LEVEL=info

## ---- Source -------------------------------------------------------
GITOPS_REPO=git@github.com:aku/afya-sahihi-deploy.git
GITOPS_BRANCH=main
GITOPS_LOCAL_CHECKOUT=/srv/afya-sahihi/gitops
GITOPS_SSH_KEY=/etc/afya-sahihi/secrets/gitops-deploy-key
GITOPS_KNOWN_HOSTS=/etc/afya-sahihi/gitops/known_hosts
GITOPS_POLL_INTERVAL_SECONDS=60

## ---- Scope --------------------------------------------------------
WATCH_PATH_K3S=deploy/k3s
WATCH_PATH_SYSTEMD=deploy/systemd
WATCH_PATH_CONFIG=deploy/config

## ---- k3s apply ----------------------------------------------------
KUBECTL_BIN=/usr/local/bin/kubectl
KUBECONFIG=/etc/afya-sahihi/kubeconfig.yaml
KUBECTL_APPLY_TIMEOUT=300s
KUBECTL_PRUNE=true                       # prune removed resources
KUBECTL_PRUNE_LABEL=app.kubernetes.io/managed-by=afya-sahihi-watcher

## ---- Bare-metal systemd units (GPU node) --------------------------
BAREMETAL_HOSTS=afya-sahihi-gpu-01.internal
BAREMETAL_SSH_USER=afya-sahihi-deploy
BAREMETAL_SSH_KEY=/etc/afya-sahihi/secrets/baremetal-ssh-key
BAREMETAL_APPLY_CMD="sudo /usr/local/bin/afya-sahihi-apply-systemd"
BAREMETAL_VALIDATE_CMD="sudo /usr/local/bin/afya-sahihi-validate-systemd"

## ---- Validation gates --------------------------------------------
PRE_APPLY_DRY_RUN=true                   # kubectl diff before apply
PRE_APPLY_SCHEMA_VALIDATE=true
PRE_APPLY_POLICY_CHECK=true              # kyverno / OPA-compatible checks

## ---- Locking ----------------------------------------------------
LOCK_FILE=/var/run/afya-sahihi-watcher.lock
LOCK_TIMEOUT_SECONDS=120

## ---- Alerts ----------------------------------------------------
ALERT_ON_FAILURE=true
ALERT_ON_DIVERGENCE=true                 # actual cluster != repo
ALERTMANAGER_URL=http://alertmanager.observability.svc.cluster.local:9093
ALERT_WEBHOOK=/etc/afya-sahihi/secrets/watcher-alert-webhook

## ---- Metrics -----------------------------------------------------
METRICS_PORT=9200                        # Prometheus scrapes
METRICS_PATH=/metrics
