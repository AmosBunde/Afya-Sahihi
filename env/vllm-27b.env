## =====================================================================
## Afya Sahihi - vLLM MedGemma 27B Server Configuration
## =====================================================================
## Runs on afya-sahihi-gpu-01 (bare metal, managed by systemd, NOT in k3s)
## Listens on port 8000. OpenAI-compatible API.
## =====================================================================

## ---- Model ---------------------------------------------------------
VLLM_MODEL=google/medgemma-27b-it
VLLM_SERVED_MODEL_NAME=medgemma-27b-it
VLLM_REVISION=                           # pin to commit SHA in prod
VLLM_DOWNLOAD_DIR=/srv/afya-sahihi/models
VLLM_TRUST_REMOTE_CODE=false

## ---- GPU / hardware ------------------------------------------------
CUDA_VISIBLE_DEVICES=0                   # single H100 80GB
VLLM_GPU_MEMORY_UTILIZATION=0.80         # leave headroom for 4B sharing GPU
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_PIPELINE_PARALLEL_SIZE=1
VLLM_MAX_NUM_SEQS=32                     # concurrent sequences
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_SWAP_SPACE_GB=4                     # CPU swap space for preempted sequences

## ---- Quantization --------------------------------------------------
VLLM_QUANTIZATION=fp8
VLLM_KV_CACHE_DTYPE=fp8_e5m2             # halves KV cache memory

## ---- Context window ------------------------------------------------
VLLM_MAX_MODEL_LEN=8192
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_PREFIX_CACHING_HASH_ALGO=sha256

## ---- Speculative decoding (draft = 4B) -----------------------------
VLLM_SPECULATIVE_MODEL=google/medgemma-4b-it
VLLM_NUM_SPECULATIVE_TOKENS=5
VLLM_SPEC_DECODING_ACCEPTANCE_METHOD=rejection_sampler
VLLM_TYPICAL_ACCEPTANCE_SAMPLER_POSTERIOR_THRESHOLD=0.09
VLLM_TYPICAL_ACCEPTANCE_SAMPLER_POSTERIOR_ALPHA=0.3

## ---- Server --------------------------------------------------------
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_UVICORN_LOG_LEVEL=info
VLLM_DISABLE_LOG_REQUESTS=false          # keep request logs for audit cross-check
VLLM_MAX_LOG_LEN=500
VLLM_ROOT_PATH=/

## ---- API surface ---------------------------------------------------
VLLM_ENABLE_AUTO_TOOL_CHOICE=false
VLLM_RETURN_TOKENS_AS_TOKEN_IDS=false
VLLM_ENABLE_LOG_PROBS=true               # CRITICAL for conformal scoring
VLLM_MAX_LOG_PROBS=20                    # top-20 logprobs per position

## ---- Security ------------------------------------------------------
VLLM_API_KEY_FILE=/etc/afya-sahihi/secrets/vllm-27b-api-key
## Token must be presented by gateway. Private network only.
VLLM_SSL_KEYFILE=
VLLM_SSL_CERTFILE=
## TLS terminated at k3s ingress, not here. Internal traffic on VLAN.

## ---- Observability -------------------------------------------------
VLLM_METRICS_ENABLED=true
VLLM_METRICS_PORT=8002                   # Prometheus scrapes /metrics on this port
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTEL_SERVICE_NAME=vllm-medgemma-27b
OTEL_RESOURCE_ATTRIBUTES=service.namespace=afya-sahihi,service.version=1.0.0,deployment.environment=production

## ---- HuggingFace ---------------------------------------------------
HF_HOME=/srv/afya-sahihi/hf-cache
HF_HUB_ENABLE_HF_TRANSFER=1
## Secret: HF_TOKEN from /etc/afya-sahihi/secrets/hf-token

## ---- Performance tuning --------------------------------------------
OMP_NUM_THREADS=8
VLLM_WORKER_MULTIPROC_METHOD=spawn
VLLM_USE_V1=1                            # vLLM v1 engine (stable as of 2026)
VLLM_ATTENTION_BACKEND=FLASHINFER        # flash attention via FlashInfer

## ---- Disk / cache ---------------------------------------------------
VLLM_CACHE_ROOT=/srv/afya-sahihi/vllm-cache
VLLM_CONFIG_ROOT=/etc/afya-sahihi/vllm
VLLM_TORCH_COMPILE_LEVEL=3               # maximum compile optimization

## ---- Limits and safety ---------------------------------------------
VLLM_MAX_PARALLEL_LOADING_WORKERS=2
VLLM_DISABLE_CUSTOM_ALL_REDUCE=false
VLLM_ENFORCE_EAGER=false                 # allow CUDA graphs
