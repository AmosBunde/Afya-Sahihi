## =====================================================================
## Afya Sahihi - Inspect AI Eval Runner
## =====================================================================
## Runs three-tier eval harness. Tier 1 on every commit (CI).
## Tier 2 nightly and pre-deploy. Tier 3 weekly with clinician loop.
## =====================================================================

SERVICE_NAME=afya-sahihi-eval
SERVICE_LOG_LEVEL=info

## ---- Inspect AI ----------------------------------------------------
INSPECT_AI_VERSION=0.3.x                 # pin minor version
INSPECT_LOG_DIR=/srv/afya-sahihi/eval/logs
INSPECT_SANDBOX=none                     # we run against our own system

## ---- Tier 1: Unit evals (CI) ---------------------------------------
TIER1_ENABLED=true
TIER1_DATASET=/srv/afya-sahihi/eval/datasets/tier1_golden.jsonl
TIER1_N_CASES=500
TIER1_SCORER=exact_match_on_key_facts
TIER1_TIMEOUT_SECONDS=120
TIER1_PASS_THRESHOLD=0.95
TIER1_FAIL_ON_REGRESSION=true

## ---- Tier 2: Regression evals (nightly + pre-deploy) ---------------
TIER2_ENABLED=true
TIER2_DATASET=/srv/afya-sahihi/eval/datasets/tier2_regression.jsonl
TIER2_N_CASES=2000
TIER2_SCORERS=ece,marginal_coverage,set_size,topic_coherence
TIER2_TIMEOUT_SECONDS=3600
TIER2_ECE_MAX=0.08
TIER2_COVERAGE_DEVIATION_MAX=0.03
TIER2_SET_SIZE_INCREASE_MAX_PCT=15
TIER2_FAIL_ON_THRESHOLD_BREACH=true
TIER2_ADVERSARIAL_RATIO=0.30
TIER2_CODE_SWITCH_RATIO=0.25
TIER2_MISSPELLING_RATIO=0.15

## ---- Tier 3: Clinician-in-the-loop (weekly) ------------------------
TIER3_ENABLED=true
TIER3_N_CASES_PER_WEEK=20
TIER3_RUBRIC_PATH=/etc/afya-sahihi/eval/tier3_rubric.yaml
TIER3_MIN_RAW_KAPPA=0.7
TIER3_MIN_AVG_SCORE=4.0
TIER3_N_REVIEWERS_PER_CASE=3
TIER3_ACQUISITION_STRATEGY=conformal_set_size
TIER3_SELECTION_CRON="0 6 * * 1"         # Monday 06:00, select week's 20

## ---- System under test ---------------------------------------------
SUT_TARGET=orchestrator                  # orchestrator | api | model_only
SUT_BASE_URL=http://gateway.afya-sahihi.svc.cluster.local:8080
SUT_API_KEY_FILE=/etc/afya-sahihi/secrets/eval-api-key
SUT_CONCURRENCY=8
SUT_REQUEST_TIMEOUT_SECONDS=60

## ---- Result storage ------------------------------------------------
RESULTS_BACKEND=postgres
RESULTS_TABLE=eval_runs
RESULTS_RETAIN_DAYS=1095                 # 3 years
RESULTS_ARCHIVE_BUCKET=afya-sahihi-artifacts
RESULTS_ARCHIVE_PREFIX=eval/

## ---- CI integration -----------------------------------------------
CI_GITHUB_ACTIONS_TOKEN_FILE=/etc/afya-sahihi/secrets/github-actions-token
CI_COMMENT_ON_PR=true
CI_FAIL_COMMIT_STATUS_ON_BREACH=true

## ---- Model under test config (pulled from .env.root) --------------
## MEDGEMMA_27B_REPO, MEDGEMMA_27B_REVISION, CORPUS_VERSION all stamped
## on every eval run for reproducibility.

## ---- Active Learning Scheduler ------------------------------------
AL_ENABLED=true
AL_ACQUISITION_FUNCTION=conformal_set_size
AL_BATCH_SIZE=20
AL_ROUND_CRON="0 6 * * 1"
AL_INITIAL_POOL_PATH=/srv/afya-sahihi/eval/datasets/al_initial_pool.jsonl
AL_LABELED_POOL_TABLE=al_labeled_pool
AL_CONTROL_ARM_RATIO=0.3                 # 30% random for causal comparison
AL_PREREGISTRATION_URL=https://osf.io/xxxxx
