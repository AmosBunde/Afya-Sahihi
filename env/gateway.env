## =====================================================================
## Afya Sahihi - Gateway API Service
## =====================================================================
## FastAPI service orchestrating the inference pipeline.
## Deployed in k3s as a Deployment. Inherits from .env.root
## =====================================================================

SERVICE_NAME=afya-sahihi-gateway
SERVICE_PORT=8080
SERVICE_WORKERS=4                        # uvicorn workers per pod
SERVICE_LOG_LEVEL=info
SERVICE_LOG_FORMAT=json

## ---- Pipeline orchestrator --------------------------------------------
ORCHESTRATOR_TIMEOUT_SECONDS=30
ORCHESTRATOR_MAX_CONCURRENT_PER_WORKER=16
ORCHESTRATOR_ENABLE_STRICT_REVIEW=true
ORCHESTRATOR_ENABLE_CONFORMAL=true
ORCHESTRATOR_FAIL_CLOSED=true            # if any stage errors, refuse safely

## ---- Downstream services ----------------------------------------------
RETRIEVAL_SERVICE_URL=http://retrieval.afya-sahihi.svc.cluster.local:8081
CONFORMAL_SERVICE_URL=http://conformal.afya-sahihi.svc.cluster.local:8082
AUDIT_SERVICE_URL=http://audit.afya-sahihi.svc.cluster.local:8083
PREFILTER_SERVICE_URL=http://prefilter.afya-sahihi.svc.cluster.local:8084

## ---- vLLM (see .env.root for shared values) ---------------------------
## VLLM_27B_BASE_URL inherited
## VLLM_4B_BASE_URL inherited

## ---- HTTP client ------------------------------------------------------
HTTPX_TIMEOUT_CONNECT=5.0
HTTPX_TIMEOUT_READ=60.0
HTTPX_TIMEOUT_WRITE=10.0
HTTPX_MAX_CONNECTIONS=100
HTTPX_MAX_KEEPALIVE_CONNECTIONS=20

## ---- Rate limiting ----------------------------------------------------
RATE_LIMIT_PER_USER_PER_MINUTE=30
RATE_LIMIT_PER_USER_PER_DAY=500
RATE_LIMIT_BURST=10
RATE_LIMIT_BACKEND=redis

## ---- Request validation ----------------------------------------------
MAX_REQUEST_SIZE_BYTES=65536
MAX_QUERY_LENGTH_CHARS=4000
MIN_QUERY_LENGTH_CHARS=3
ALLOWED_LANGUAGES=en,sw,en-sw
PHI_SCRUBBER_ENABLED=true

## ---- CORS (adjust per environment) ------------------------------------
CORS_ALLOWED_ORIGINS=https://afya-sahihi.aku.edu
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID

## ---- SSE streaming ----------------------------------------------------
SSE_KEEPALIVE_INTERVAL_SECONDS=15
SSE_MAX_STREAM_DURATION_SECONDS=120
SSE_BUFFER_SIZE=4096

## ---- Health ----------------------------------------------------------
HEALTH_CHECK_PATH=/healthz
READY_CHECK_PATH=/readyz
READY_CHECK_DEPENDENCIES=postgres,redis,vllm_27b,vllm_4b,retrieval,conformal

## ---- Graceful shutdown ----------------------------------------------
SHUTDOWN_DRAIN_SECONDS=15
SHUTDOWN_FORCE_AFTER_SECONDS=30
