## =====================================================================
## Afya Sahihi - Ingestion Worker
## =====================================================================
## Offline batch job. Runs as k8s CronJob or on-demand via CLI.
## Parses MoH PDFs with Docling, extracts structural metadata, embeds,
## writes to Postgres.
## =====================================================================

SERVICE_NAME=afya-sahihi-ingestion
SERVICE_LOG_LEVEL=info
SERVICE_LOG_FORMAT=json

## ---- Source --------------------------------------------------------
SOURCE_BUCKET=afya-sahihi-corpus
SOURCE_PREFIX=moh-kenya/v1/
SOURCE_WATCH_MODE=manifest               # manifest | scan
SOURCE_MANIFEST_PATH=s3://afya-sahihi-corpus/manifests/current.yaml

## ---- Docling ------------------------------------------------------
DOCLING_VERSION=2.9.0
DOCLING_PIPELINE=standard
DOCLING_OCR_ENABLED=true
DOCLING_OCR_LANGUAGES=eng,swa
DOCLING_EXTRACT_TABLES=true
DOCLING_EXTRACT_FIGURES=true
DOCLING_EXTRACT_FORMULAS=false
DOCLING_PRESERVE_READING_ORDER=true

## ---- Chunking ------------------------------------------------------
CHUNKER=hybrid                           # hybrid | hierarchical | fixed
CHUNKER_MAX_TOKENS=512
CHUNKER_MIN_TOKENS=64
CHUNKER_OVERLAP_TOKENS=64
CHUNKER_MERGE_PEERS=true
CHUNKER_TOKENIZER=BAAI/bge-m3

## ---- Structural metadata extraction --------------------------------
STRUCTURAL_METADATA_ENABLED=true
STRUCTURAL_CAPTURE_BBOX=true
STRUCTURAL_CAPTURE_SECTION_PATH=true
STRUCTURAL_CAPTURE_VISUAL_EMPHASIS=true
STRUCTURAL_CAPTURE_TABLE_LINEAGE=true
STRUCTURAL_MAX_SECTION_DEPTH=6

## ---- Visual emphasis rules (color -> semantic tag) ----------------
## Configures which colors in source PDFs map to which semantic tags.
## Loaded from YAML for per-corpus customization.
EMPHASIS_RULES_PATH=/etc/afya-sahihi/ingestion/emphasis_rules.yaml

## ---- Embedding -----------------------------------------------------
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DEVICE=cuda:0                   # or cpu for small corpora
EMBEDDER_BATCH_SIZE=32
EMBEDDER_MAX_LENGTH=512
EMBEDDER_NORMALIZE=true
EMBEDDER_MATRYOSHKA_DIM=1024

## ---- Destination ---------------------------------------------------
## Postgres connection inherited from .env.root
INGESTION_BATCH_INSERT_SIZE=500
INGESTION_ON_DUPLICATE=skip              # skip | replace | error
INGESTION_INDEX_AFTER_BATCH=true

## ---- Provenance ----------------------------------------------------
PROVENANCE_HASH_ALGORITHM=sha256
PROVENANCE_STORE_SOURCE_COPY=true        # preserve original PDF in MinIO
PROVENANCE_SOURCE_COPY_BUCKET=afya-sahihi-corpus-archive

## ---- Idempotency ---------------------------------------------------
IDEMPOTENCY_KEY_STRATEGY=document_hash_plus_chunker_version
IDEMPOTENCY_STATE_TABLE=ingestion_runs
IDEMPOTENCY_SKIP_IF_UNCHANGED=true

## ---- Concurrency ---------------------------------------------------
WORKER_CONCURRENCY=4                     # documents in parallel
WORKER_TIMEOUT_SECONDS=600               # per document
WORKER_RETRY_ATTEMPTS=3
WORKER_RETRY_BACKOFF_SECONDS=30

## ---- Scheduling ----------------------------------------------------
INGESTION_SCHEDULE_CRON="0 3 * * 1"      # weekly Monday 03:00, re-check manifest

## ---- Quality gates -------------------------------------------------
QUALITY_MIN_CHUNKS_PER_DOC=3
QUALITY_MAX_CHUNKS_PER_DOC=5000
QUALITY_MIN_AVG_CHUNK_TOKENS=40
QUALITY_REJECT_ON_FAILURE=true
