## =====================================================================
## Afya Sahihi - Audit Service
## =====================================================================
## Immutable append-only log of every query-response cycle.
## IRB-compliant: 7-year retention, PHI-scrubbed before write.
## =====================================================================

SERVICE_NAME=afya-sahihi-audit
SERVICE_PORT=8083
SERVICE_WORKERS=2
SERVICE_LOG_LEVEL=info

## ---- Storage -------------------------------------------------------
AUDIT_TABLE=queries_audit
AUDIT_APPEND_ONLY=true                   # enforced at DB level via trigger
AUDIT_WRITE_MODE=sync                    # sync | async (sync = fail closed)
AUDIT_BATCH_SIZE=1
AUDIT_RETENTION_DAYS=2555

## ---- PHI scrubbing (final line of defense) -------------------------
PHI_SCRUBBER_ENABLED=true
PHI_SCRUBBER_LOCAL_ONLY=true             # never send to external service
PHI_PATTERNS_PATH=/etc/afya-sahihi/audit/phi_patterns.yaml
PHI_REPLACEMENT=<REDACTED>
PHI_FAIL_OPEN=false                      # if scrubber fails, refuse to write

## ---- Hash chaining -------------------------------------------------
HASH_CHAIN_ENABLED=true                  # tamper-evident audit log
HASH_ALGORITHM=sha256
HASH_CHAIN_GENESIS_FILE=/etc/afya-sahihi/audit/genesis.hash

## ---- Export for IRB / research -------------------------------------
EXPORT_ALLOWED_ROLES=research_lead,irb_auditor
EXPORT_REQUIRE_TWO_PERSON_APPROVAL=true
EXPORT_DEFAULT_FORMAT=jsonl
EXPORT_ANONYMIZATION_LEVEL=k5            # k-anonymity with k=5
