## =====================================================================
## Afya Sahihi - Observability Stack
## =====================================================================
## OTel Collector → fan-out to Tempo (traces), Prometheus (metrics),
## Loki (logs), Phoenix (LLM spans). Grafana is the unified UI.
## =====================================================================

## ---- OTel Collector (DaemonSet) ------------------------------------
OTEL_COLLECTOR_VERSION=0.100.x
OTEL_COLLECTOR_CONFIG_PATH=/etc/otel/collector.yaml
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_MEM_LIMIT_MIB=1024
OTEL_COLLECTOR_QUEUE_SIZE=5000
OTEL_COLLECTOR_BATCH_SIZE=512
OTEL_COLLECTOR_BATCH_TIMEOUT=5s

## OTel pipeline destinations
OTEL_EXPORT_TEMPO=http://tempo.observability.svc.cluster.local:4317
OTEL_EXPORT_PROMETHEUS_RW=http://prometheus.observability.svc.cluster.local:9090/api/v1/write
OTEL_EXPORT_LOKI=http://loki.observability.svc.cluster.local:3100/loki/api/v1/push
OTEL_EXPORT_PHOENIX=http://phoenix.observability.svc.cluster.local:6006

## ---- Grafana Tempo (traces) ----------------------------------------
TEMPO_VERSION=2.5.x
TEMPO_LISTEN_PORT=3200
TEMPO_GRPC_PORT=4317
TEMPO_STORAGE_BACKEND=s3
TEMPO_STORAGE_S3_BUCKET=afya-sahihi-traces
TEMPO_STORAGE_S3_ENDPOINT=minio.afya-sahihi.internal
TEMPO_RETENTION_DAYS=30
TEMPO_MAX_SEARCH_DURATION=168h           # 7 days max query window
TEMPO_METRICS_GENERATOR_ENABLED=true     # service graph + span metrics

## ---- Arize Phoenix (LLM-specific spans) ----------------------------
PHOENIX_VERSION=4.x
PHOENIX_LISTEN_PORT=6006
PHOENIX_GRPC_PORT=6007
PHOENIX_STORAGE_URL=postgresql://phoenix:CHANGEME@afya-sahihi-data-01.internal:5432/phoenix
PHOENIX_WORKING_DIR=/srv/afya-sahihi/phoenix
PHOENIX_LOG_LEVEL=info
PHOENIX_ENABLE_AUTH=true

## ---- Prometheus (metrics) ------------------------------------------
PROMETHEUS_VERSION=2.55.x
PROMETHEUS_LISTEN_PORT=9090
PROMETHEUS_CONFIG_PATH=/etc/prometheus/prometheus.yaml
PROMETHEUS_RETENTION=30d
PROMETHEUS_STORAGE_PATH=/srv/afya-sahihi/prometheus
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_REMOTE_WRITE_ENABLED=false    # no remote write for now

## Alertmanager
ALERTMANAGER_VERSION=0.27.x
ALERTMANAGER_LISTEN_PORT=9093
ALERTMANAGER_CONFIG_PATH=/etc/alertmanager/alertmanager.yaml
ALERTMANAGER_SLACK_WEBHOOK_FILE=/etc/afya-sahihi/secrets/slack-webhook
ALERTMANAGER_PAGERDUTY_KEY_FILE=/etc/afya-sahihi/secrets/pagerduty-key

## ---- Loki (logs) ---------------------------------------------------
LOKI_VERSION=3.x
LOKI_LISTEN_PORT=3100
LOKI_STORAGE_BACKEND=s3
LOKI_STORAGE_S3_BUCKET=afya-sahihi-logs
LOKI_STORAGE_S3_ENDPOINT=minio.afya-sahihi.internal
LOKI_RETENTION_DAYS=30
LOKI_MAX_QUERY_LENGTH=721h               # ~30 days
LOKI_INGESTION_RATE_MB=10
LOKI_INGESTION_BURST_MB=20

## Promtail (log shipper, runs as DaemonSet)
PROMTAIL_VERSION=3.x
PROMTAIL_POSITIONS_FILE=/srv/afya-sahihi/promtail/positions.yaml
PROMTAIL_SCRAPE_JOURNAL=true
PROMTAIL_SCRAPE_CONTAINER_LOGS=true

## ---- Grafana (dashboards) ------------------------------------------
GRAFANA_VERSION=11.x
GRAFANA_LISTEN_PORT=3000
GRAFANA_ROOT_URL=https://afya-sahihi.aku.edu/grafana
GRAFANA_AUTH_OIDC_ENABLED=true
GRAFANA_AUTH_OIDC_AUTH_URL=https://auth.aku.edu/realms/afya-sahihi/protocol/openid-connect/auth
GRAFANA_AUTH_OIDC_TOKEN_URL=https://auth.aku.edu/realms/afya-sahihi/protocol/openid-connect/token
GRAFANA_AUTH_ANONYMOUS_ENABLED=false
GRAFANA_SECURITY_ADMIN_USER=afya-sahihi-admin
## Secret: GRAFANA_SECURITY_ADMIN_PASSWORD via Sealed Secrets
GRAFANA_PROVISIONING_PATH=/etc/grafana/provisioning
GRAFANA_DASHBOARDS_PATH=/var/lib/grafana/dashboards

## Pre-provisioned dashboards
GRAFANA_DASHBOARD_RED_METRICS=true       # Rate, Error, Duration per service
GRAFANA_DASHBOARD_LLM_METRICS=true       # TTFT, tokens/sec, KV cache hit rate
GRAFANA_DASHBOARD_RETRIEVAL_METRICS=true # latency, fusion weights, reranker scores
GRAFANA_DASHBOARD_CONFORMAL_METRICS=true # coverage, set size, drift
GRAFANA_DASHBOARD_EVAL_METRICS=true      # Tier 1/2/3 trends
GRAFANA_DASHBOARD_GPU_METRICS=true       # DCGM utilization, memory, power

## ---- Node/DCGM exporters ------------------------------------------
NODE_EXPORTER_VERSION=1.8.x
NODE_EXPORTER_PORT=9100
DCGM_EXPORTER_VERSION=3.3.x              # GPU metrics
DCGM_EXPORTER_PORT=9400
POSTGRES_EXPORTER_VERSION=0.15.x
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_VERSION=1.60.x
REDIS_EXPORTER_PORT=9121
NGINX_EXPORTER_VERSION=1.1.x
NGINX_EXPORTER_PORT=9113
