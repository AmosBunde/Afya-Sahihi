## =====================================================================
## Afya Sahihi - vLLM MedGemma 4B Server Configuration
## =====================================================================
## Dual role:
##   1) Pre-filter classifier via LoRA adapter + classification head
##   2) Draft model for 27B speculative decoding (loaded by 27B server)
## This file configures the standalone HTTP server for role (1).
## Listens on port 8001.
## =====================================================================

## ---- Model ---------------------------------------------------------
VLLM_MODEL=google/medgemma-4b-it
VLLM_SERVED_MODEL_NAME=medgemma-4b-it
VLLM_REVISION=                           # pin to commit SHA in prod
VLLM_DOWNLOAD_DIR=/srv/afya-sahihi/models
VLLM_TRUST_REMOTE_CODE=false

## ---- LoRA adapter (pre-filter classifier) --------------------------
VLLM_ENABLE_LORA=true
VLLM_MAX_LORAS=2
VLLM_MAX_LORA_RANK=16
VLLM_LORA_MODULES=prefilter=/srv/afya-sahihi/models/afya-sahihi-prefilter-v1,reranker=/srv/afya-sahihi/models/afya-sahihi-reranker-v1

## ---- GPU / hardware ------------------------------------------------
CUDA_VISIBLE_DEVICES=0                   # same H100, SM partitioned
VLLM_GPU_MEMORY_UTILIZATION=0.15         # leave 80% for 27B, 5% OS
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_PIPELINE_PARALLEL_SIZE=1
VLLM_MAX_NUM_SEQS=64                     # pre-filter is fast, allow high concurrency
VLLM_MAX_NUM_BATCHED_TOKENS=4096

## ---- Quantization --------------------------------------------------
VLLM_QUANTIZATION=                       # BF16 native, no quantization
VLLM_KV_CACHE_DTYPE=auto

## ---- Context window ------------------------------------------------
VLLM_MAX_MODEL_LEN=4096                  # pre-filter needs less context
VLLM_ENABLE_PREFIX_CACHING=true

## ---- Classifier head -----------------------------------------------
## The classifier head is NOT in vLLM itself; it is a FastAPI wrapper
## at `services/prefilter/` that calls vLLM with the LoRA adapter,
## extracts the final hidden state via the logits API, and runs the
## classification layer in torch. See services/prefilter/README.md.

CLASSIFIER_HEAD_PATH=/srv/afya-sahihi/models/afya-sahihi-prefilter-head-v1.safetensors
CLASSIFIER_HEAD_N_INTENTS=42
CLASSIFIER_HEAD_INTENT_LABELS_PATH=/etc/afya-sahihi/prefilter/intents.yaml
CLASSIFIER_HEAD_SAFETY_THRESHOLD=0.5

## ---- Server --------------------------------------------------------
VLLM_HOST=0.0.0.0
VLLM_PORT=8001
VLLM_UVICORN_LOG_LEVEL=info
VLLM_DISABLE_LOG_REQUESTS=false
VLLM_ROOT_PATH=/

## ---- API surface ---------------------------------------------------
VLLM_ENABLE_LOG_PROBS=true
VLLM_MAX_LOG_PROBS=10

## ---- Security ------------------------------------------------------
VLLM_API_KEY_FILE=/etc/afya-sahihi/secrets/vllm-4b-api-key

## ---- Observability -------------------------------------------------
VLLM_METRICS_ENABLED=true
VLLM_METRICS_PORT=8003
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTEL_SERVICE_NAME=vllm-medgemma-4b
OTEL_RESOURCE_ATTRIBUTES=service.namespace=afya-sahihi,service.version=1.0.0,deployment.environment=production

## ---- HuggingFace ---------------------------------------------------
HF_HOME=/srv/afya-sahihi/hf-cache
HF_HUB_ENABLE_HF_TRANSFER=1

## ---- Performance tuning --------------------------------------------
OMP_NUM_THREADS=4
VLLM_WORKER_MULTIPROC_METHOD=spawn
VLLM_USE_V1=1
VLLM_ATTENTION_BACKEND=FLASHINFER

## ---- Disk / cache ---------------------------------------------------
VLLM_CACHE_ROOT=/srv/afya-sahihi/vllm-cache-4b
VLLM_CONFIG_ROOT=/etc/afya-sahihi/vllm
VLLM_TORCH_COMPILE_LEVEL=3

## ---- NOTE on the 27B speculative draft role ------------------------
## For role (2), the 27B server at vllm-27b.env loads this same model
## as its speculative draft via VLLM_SPECULATIVE_MODEL. That is a
## separate load of the same weights inside the 27B process. Do not
## attempt to share the vLLM server across the two roles.
