## =====================================================================
## Afya Sahihi - Postgres 16 Server
## =====================================================================
## Bare metal on afya-sahihi-data-01. Tuned for RAG workload:
## HNSW vector search + BM25 + JSONB + application state.
## =====================================================================

## ---- Identity -----------------------------------------------------
POSTGRES_VERSION=16.2
POSTGRES_DB=afya-sahihi
POSTGRES_USER=hakika_admin
## Secret: POSTGRES_PASSWORD via Sealed Secrets / systemd credential

## ---- Paths --------------------------------------------------------
PGDATA=/var/lib/postgresql/16/afya-sahihi
PGLOG=/var/log/postgresql
PG_WAL_ARCHIVE=/srv/afya-sahihi/pg-wal-archive

## ---- Listener -----------------------------------------------------
POSTGRES_LISTEN_ADDRESSES=afya-sahihi-data-01.internal
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200

## ---- Memory (assuming 128GB node) --------------------------------
POSTGRES_SHARED_BUFFERS=32GB
POSTGRES_EFFECTIVE_CACHE_SIZE=96GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAINTENANCE_WORK_MEM=2GB
POSTGRES_WAL_BUFFERS=64MB

## ---- WAL / durability --------------------------------------------
POSTGRES_WAL_LEVEL=replica
POSTGRES_MAX_WAL_SIZE=8GB
POSTGRES_MIN_WAL_SIZE=2GB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_ARCHIVE_MODE=on
POSTGRES_ARCHIVE_COMMAND="test ! -f /srv/afya-sahihi/pg-wal-archive/%f && cp %p /srv/afya-sahihi/pg-wal-archive/%f"

## ---- Parallelism -------------------------------------------------
POSTGRES_MAX_WORKER_PROCESSES=16
POSTGRES_MAX_PARALLEL_WORKERS=16
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=4
POSTGRES_MAX_PARALLEL_MAINTENANCE_WORKERS=4

## ---- Query planner -----------------------------------------------
POSTGRES_RANDOM_PAGE_COST=1.1            # NVMe-backed
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200
POSTGRES_DEFAULT_STATISTICS_TARGET=200

## ---- Extensions (load on startup) --------------------------------
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements,pg_search,pg_cron,auto_explain

## ---- Logging -----------------------------------------------------
POSTGRES_LOG_DESTINATION=stderr,csvlog
POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms
POSTGRES_LOG_CHECKPOINTS=on
POSTGRES_LOG_LOCK_WAITS=on
POSTGRES_LOG_TEMP_FILES=10MB

## ---- SSL ---------------------------------------------------------
POSTGRES_SSL=on
POSTGRES_SSL_CERT_FILE=/etc/postgresql/16/afya-sahihi/server.crt
POSTGRES_SSL_KEY_FILE=/etc/postgresql/16/afya-sahihi/server.key
POSTGRES_SSL_CA_FILE=/etc/postgresql/16/afya-sahihi/ca.crt

## ---- Backup (pgBackRest) ----------------------------------------
PGBACKREST_STANZA=afya-sahihi
PGBACKREST_REPO1_TYPE=s3
PGBACKREST_REPO1_S3_ENDPOINT=minio.afya-sahihi.internal
PGBACKREST_REPO1_S3_BUCKET=afya-sahihi-backups
PGBACKREST_REPO1_S3_REGION=us-east-1
PGBACKREST_REPO1_RETENTION_FULL=4        # 4 weeks of full backups
PGBACKREST_REPO1_RETENTION_DIFF=7        # 7 daily differentials
PGBACKREST_FULL_BACKUP_CRON="0 2 * * 0"  # Sunday 02:00
PGBACKREST_DIFF_BACKUP_CRON="0 2 * * 1-6"

## ---- HNSW defaults for pgvector ---------------------------------
PGVECTOR_HNSW_MAX_ELEMENTS=1000000
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_HNSW_M=16
