## =====================================================================
## Afya Sahihi - Root Environment Configuration
## =====================================================================
## This is the canonical reference. All service-specific .env files
## inherit or override values from here. Never commit real secrets.
## Use Sealed Secrets (see deploy/k3s/sealed-secrets/) for production.
## =====================================================================

## ---- System identity -----------------------------------------------
HAKIKA_ENV=production                    # production | staging | dev
HAKIKA_VERSION=1.0.0
HAKIKA_DEPLOYMENT_ID=aku-nairobi-prod
HAKIKA_REGION=KE-NAIROBI
HAKIKA_DATA_RESIDENCY=KE                 # ISO country code for PHI jurisdiction

## ---- Core model pinning --------------------------------------------
## These are the single source of truth for which model weights are in use.
## Change here, roll forward through staging, then production.

MEDGEMMA_27B_REPO=google/medgemma-27b-it
MEDGEMMA_27B_REVISION=main               # pin to commit SHA in prod
MEDGEMMA_27B_QUANTIZATION=fp8

MEDGEMMA_4B_REPO=google/medgemma-4b-it
MEDGEMMA_4B_REVISION=main                # pin to commit SHA in prod
MEDGEMMA_4B_QUANTIZATION=bf16

EMBEDDING_MODEL_REPO=BAAI/bge-m3
EMBEDDING_MODEL_DIM=1024                 # matryoshka truncation from 1024 native
EMBEDDING_MODEL_REVISION=main

RERANKER_MODEL_REPO=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_REVISION=main

## ---- Corpus versioning ---------------------------------------------
## Every inference run stamps these. Papers cite corpus_version.
CORPUS_VERSION=v1.0
CORPUS_SOURCE=moh-kenya-guidelines
CORPUS_LAST_REINDEX_ISO=2026-04-16T00:00:00Z

## ---- Postgres ------------------------------------------------------
PG_HOST=afya-sahihi-data-01.internal
PG_PORT=5432
PG_DATABASE=afya-sahihi
PG_USER=hakika_app
PG_SSLMODE=verify-full
PG_SSLROOTCERT=/etc/afya-sahihi/certs/pg-ca.crt
## Secret: PG_PASSWORD is pulled from Sealed Secrets, never here

PG_POOL_MIN=4
PG_POOL_MAX=20
PG_POOL_STATEMENT_CACHE_SIZE=1024
PG_COMMAND_TIMEOUT_SECONDS=30

## HNSW parameters for pgvector
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_HNSW_EF_SEARCH=40

## ---- Redis ---------------------------------------------------------
REDIS_HOST=afya-sahihi-data-01.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=true
## Secret: REDIS_PASSWORD via Sealed Secrets

## ---- MinIO (S3-compatible object storage) --------------------------
MINIO_ENDPOINT=https://minio.afya-sahihi.internal
MINIO_REGION=us-east-1                   # MinIO convention, not geographic
MINIO_BUCKET_CORPUS=afya-sahihi-corpus
MINIO_BUCKET_ARTIFACTS=afya-sahihi-artifacts
MINIO_BUCKET_MODELS=afya-sahihi-models
MINIO_BUCKET_BACKUPS=afya-sahihi-backups
## Secret: MINIO_ACCESS_KEY, MINIO_SECRET_KEY via Sealed Secrets

## ---- vLLM endpoints (OpenAI-compatible) ----------------------------
VLLM_27B_BASE_URL=http://afya-sahihi-gpu-01.internal:8000/v1
VLLM_27B_MODEL_NAME=medgemma-27b-it
VLLM_27B_TIMEOUT_SECONDS=60

VLLM_4B_BASE_URL=http://afya-sahihi-gpu-01.internal:8001/v1
VLLM_4B_MODEL_NAME=medgemma-4b-it
VLLM_4B_TIMEOUT_SECONDS=10

## ---- Pipeline defaults ---------------------------------------------
PIPELINE_PREFILTER_THRESHOLD=0.65
PIPELINE_STRICT_REVIEW_CATEGORIES=dosing,contraindication,pediatric,pregnancy
PIPELINE_MAX_INPUT_TOKENS=2048
PIPELINE_MAX_OUTPUT_TOKENS=1024
PIPELINE_GENERATION_TEMPERATURE=0.1
PIPELINE_GENERATION_TOP_P=0.9
PIPELINE_GENERATION_SEED=20260416

## ---- Retrieval defaults --------------------------------------------
RETRIEVAL_TOP_K=6
RETRIEVAL_OVER_FETCH_MULT=3              # fetch 3x K before reranking
RETRIEVAL_RRF_K=60                       # Reciprocal Rank Fusion constant
RETRIEVAL_MIN_SIMILARITY=0.35
RETRIEVAL_CHUNK_MAX_TOKENS=512
RETRIEVAL_CHUNK_OVERLAP_TOKENS=64

## ---- Conformal prediction ------------------------------------------
CP_TARGET_COVERAGE=0.90                  # 1 - alpha
CP_CALIBRATION_SET_MIN_SIZE=500
CP_QUANTILE_REFRESH_CRON="0 2 * * *"     # daily at 02:00
CP_STRATA=domain,language,facility_level
CP_METHOD=weighted_split                 # weighted_split | adaptive | mondrian
CP_NONCONFORMITY_SCORE=clinical_harm_weighted

## ---- Observability -------------------------------------------------
OTEL_SERVICE_NAMESPACE=afya-sahihi
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0              # keep all traces in production; reduce if volume grows
OTEL_LOG_LEVEL=info
OTEL_METRIC_EXPORT_INTERVAL_MS=15000

PROMETHEUS_SCRAPE_INTERVAL=15s
LOKI_ENDPOINT=http://loki.observability.svc.cluster.local:3100
TEMPO_ENDPOINT=http://tempo.observability.svc.cluster.local:3200
PHOENIX_ENDPOINT=http://phoenix.observability.svc.cluster.local:6006

## ---- Auth and identity ---------------------------------------------
OIDC_ISSUER=https://auth.aku.edu/realms/afya-sahihi
OIDC_CLIENT_ID=afya-sahihi-frontend
OIDC_AUDIENCE=afya-sahihi-api
## Secret: OIDC_CLIENT_SECRET via Sealed Secrets
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
SESSION_MAX_AGE_SECONDS=28800            # 8 hours, matches shift length

## ---- Feature flags -------------------------------------------------
FEATURE_STRICT_REVIEW_ENABLED=true
FEATURE_SPECULATIVE_DECODING_ENABLED=true
FEATURE_ACTIVE_LEARNING_ENABLED=true
FEATURE_SWAHILI_CODE_SWITCH=true
FEATURE_CONFORMAL_SETS_IN_UI=true
FEATURE_PROVENANCE_PANEL=true

## ---- Governance ----------------------------------------------------
AUDIT_LOG_RETENTION_DAYS=2555            # 7 years, Kenyan clinical standard
PHI_SCRUBBER_ENABLED=true
PHI_SCRUBBER_MODEL=local-regex-v2        # do not send queries to external PHI scrubbers
IRB_APPROVAL_ID=AKU-IRB-2026-0147
NACOSTI_PERMIT_ID=NACOSTI/P/26/12345
