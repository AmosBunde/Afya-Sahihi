## =====================================================================
## Afya Sahihi - Frontend (React 19 + Vite)
## =====================================================================
## Static build served by nginx. Variables prefixed VITE_ are embedded
## at build time. Non-VITE_ variables are server-side only (nginx).
## =====================================================================

## ---- Build-time (embedded in bundle) -------------------------------
VITE_APP_NAME=Afya Sahihi
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=https://afya-sahihi.aku.edu/api
VITE_SSE_RECONNECT_DELAY_MS=3000
VITE_DEFAULT_LOCALE=en
VITE_AVAILABLE_LOCALES=en,sw

VITE_OIDC_AUTHORITY=https://auth.aku.edu/realms/afya-sahihi
VITE_OIDC_CLIENT_ID=afya-sahihi-frontend
VITE_OIDC_REDIRECT_URI=https://afya-sahihi.aku.edu/auth/callback
VITE_OIDC_SCOPE=openid profile email roles

## ---- Feature toggles (build-time) ----------------------------------
VITE_FEATURE_CONFORMAL_SETS=true
VITE_FEATURE_PROVENANCE_PANEL=true
VITE_FEATURE_CITATION_HIGHLIGHT=true
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_OFFLINE_BANNER=true

## ---- Telemetry (respect browser DNT) -------------------------------
VITE_OTEL_BROWSER_ENDPOINT=https://afya-sahihi.aku.edu/otel-collector
VITE_TELEMETRY_SAMPLE_RATE=0.1

## ---- Server-side (nginx) -------------------------------------------
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=256k
NGINX_CACHE_STATIC_ASSETS=true
NGINX_CACHE_TTL=30d
NGINX_GZIP=on
NGINX_BROTLI=on
NGINX_SECURITY_HEADERS=true
NGINX_CSP_REPORT_URI=https://afya-sahihi.aku.edu/csp-report
