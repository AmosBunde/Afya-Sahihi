{
  "title": "Afya Sahihi — Conformal",
  "uid": "afya-conformal",
  "tags": ["afya-sahihi", "conformal"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "title": "Marginal coverage (1h avg)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg_over_time(afya_sahihi_conformal_coverage[1h])",
          "legendFormat": "coverage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0.8,
          "max": 1.0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.87 },
              { "color": "green", "value": 0.89 }
            ]
          }
        }
      }
    },
    {
      "title": "ECE (expected calibration error)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "afya_sahihi_conformal_ece", "legendFormat": "ECE" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.06 },
              { "color": "red", "value": 0.08 }
            ]
          }
        }
      }
    },
    {
      "title": "Prediction set size by stratum",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg by (stratum) (afya_sahihi_conformal_set_size)",
          "legendFormat": "{{stratum}}"
        }
      ]
    },
    {
      "title": "Drift MMD²",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "afya_sahihi_conformal_drift_mmd_squared", "legendFormat": "mmd²" }
      ]
    }
  ]
}
