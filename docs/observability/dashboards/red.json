{
  "title": "Afya Sahihi — RED (Rate, Errors, Duration)",
  "uid": "afya-red",
  "tags": ["afya-sahihi", "red"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(afya_sahihi:request_rate:5m, service)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Request rate per service (req/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "afya_sahihi:request_rate:5m{service=~\"$service\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "title": "Error rate (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "afya_sahihi:error_rate:5m{service=~\"$service\"} * 100",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "P99 latency (s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "afya_sahihi:latency_p99:5m{service=~\"$service\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
