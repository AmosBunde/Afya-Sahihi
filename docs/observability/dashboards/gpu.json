{
  "title": "Afya Sahihi — GPU (DCGM)",
  "uid": "afya-gpu",
  "tags": ["afya-sahihi", "gpu"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "title": "GPU utilization %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "title": "GPU memory used (GiB)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED / 1024",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "gigabytes" }
      }
    },
    {
      "title": "GPU temperature (°C)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU power draw (W)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" } }
    }
  ]
}
